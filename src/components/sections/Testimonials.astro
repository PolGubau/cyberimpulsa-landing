---
import { Check, StarIcon } from "@lucide/astro";
import SectionHeader from "../ui/SectionHeader.astro";

const siteUrl = "https://klientify.com";

const testimonials = [
  {
    quote:
      "Llevábamos meses intentando captar clientes enterprise sin resultados. Con Klientify, en las primeras 6 semanas teníamos 3 reuniones con empresas de más de 200 empleados. El sistema funciona. Lo que más me sorprendió fue la especialización: saben exactamente cómo hablar con CTOs y responsables de compras en el sector tech.",
    author: "Rafa de la Vega",
    role: "CEO",
    company: "THE CLOUD GROUP",
    project: "Captación B2B Internacional",
    rating: 5,
    metrics:
      "27.000€ en 2 meses · 180.000€ presupuestados · 3 clientes enterprise",
    highlight: "27.000€ captados en los primeros 2 meses",
  },
  {
    quote:
      "Teníamos un buen producto de software B2B pero no sabíamos llegar a las empresas correctas. Klientify montó el sistema de captación, automatizó el seguimiento y creó contenido que realmente conecta con nuestro cliente ideal. En 2 meses teníamos presupuestos por encima de 80.000€ activos.",
    author: "Martín Castellanos",
    role: "CEO",
    company: "SoftDev Solutions",
    project: "Sistema de Captación B2B",
    rating: 5,
    metrics: "20.000€ en 2 meses · +80.000€ presupuestados · CRM automatizado",
    highlight: "Pipeline de 80.000€ en 8 semanas",
  },
  {
    quote:
      "Como empresa de ciberseguridad, el ciclo de venta es largo y complejo. Klientify entendió eso desde el primer día. Construyeron una estrategia específica para nuestro sector: contenido técnico de valor, campañas dirigidas a CISOs y un proceso de seguimiento que realmente cierra. Los resultados hablan solos.",
    author: "Patricia González",
    role: "Directora Comercial",
    company: "SecureLayer",
    project: "Estrategia de Marketing B2B",
    rating: 5,
    metrics:
      "Ciclo de venta reducido un 40% · 5 nuevos contratos · ROI positivo mes 3",
    highlight: "Estrategia adaptada a ventas enterprise de ciberseguridad",
  },
];
---

<section class="landing-section bg-accent/5">
  <SectionHeader
    title="Lo que dicen nuestros clientes"
    description="Resultados reales de empresas que confiaron en nosotros"
    tag="Testimonios"
    align="center"
  />

  <div class="grid md:grid-cols-3 gap-4 max-w-6xl mx-auto" data-stagger="100">
    {
      testimonials.map((testimonial) => (
        <div
          class="testimonial-card bg-background border border-muted shadow-pastel rounded-2xl p-8 flex flex-col gap-4"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
        >
          {/* Rating */}
          <div class="flex gap-0">
            {Array.from({ length: testimonial.rating }).map(() => (
              <StarIcon
                class="size-5 text-yellow-400"
                fill="currentColor"
                stroke="currentColor"
              />
            ))}
          </div>

          {/* Highlight badge */}
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-primary/10 w-fit text-primary text-xs font-semibold">
            <Check class="size-3" />
            {testimonial.highlight}
          </div>

          {/* Quote */}
          <blockquote class="text-foreground leading-relaxed flex-1">
            "{testimonial.quote}"
          </blockquote>

          {/* Metrics */}
          <div class="px-4 py-3 rounded-lg border border-muted mb-3">
            <p class="text-sm font-semibold text-muted-foreground">
              {testimonial.metrics}
            </p>
          </div>

          {/* Author */}
          <div class="flex items-start gap-3 pt-2 border-t border-muted">
            <div class="size-10 aspect-square rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-lg mt-2">
              {testimonial.author.charAt(0)}
            </div>
            <div class="mt-2">
              <p class="font-semibold text-foreground">{testimonial.author}</p>
              <p class="text-xs text-muted-foreground">
                {testimonial.role}, {testimonial.company}
              </p>
              <p class="text-xs text-muted-foreground mt-1">
                Proyecto: {testimonial.project}
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  {/* Trust indicators */}
  <div
    class="flex flex-wrap justify-center items-center gap-8 text-sm text-muted-foreground"
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
  >
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />
      <span>Solo empresas B2B tecnológicas</span>
    </div>
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />
      <span>Resultados en los primeros 2 meses</span>
    </div>
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />
      <span>Sistema probado y replicable</span>
    </div>
  </div>
</section>

<!-- Schema.org Review agregado -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Klientify",
    url: siteUrl,
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "5",
      bestRating: "5",
      worstRating: "1",
      reviewCount: String(testimonials.length),
    },
    review: testimonials.map((t) => ({
      "@type": "Review",
      reviewRating: {
        "@type": "Rating",
        ratingValue: String(t.rating),
        bestRating: "5",
      },
      author: {
        "@type": "Person",
        name: t.author,
        jobTitle: t.role,
        worksFor: {
          "@type": "Organization",
          name: t.company,
        },
      },
      reviewBody: t.quote,
      name: t.highlight,
    })),
  })}
/>
