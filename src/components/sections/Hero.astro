---
import { branding } from "~/config/branding";
import { copy } from "~/shared/lib/copy";
import Button from "../ui/Button.astro";
import Globe from "../ui/Globe.astro";
import ClientsCarousel from "./ClientsCarousel.astro";

const { hero } = copy;
const { calendlyUrl } = branding.contact;
const totalDuration = hero.sectors.length * 3;
---

<section id="hero" class="relative flex flex-col w-full px-6">
  <!-- Bloque superior: grid 2 columnas en desktop, min 80vh -->
  <div
    class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center pt-28 pb-16 min-h-[80vh] max-w-6xl mx-auto w-full"
  >
    <!-- Columna izquierda: texto + CTA -->
    <div class="flex flex-col gap-10 justify-center items-start">
      <!-- Headline + subtitle -->
      <div class="flex flex-col items-start gap-4" data-stagger="120">
        <h1
          class="text-4xl md:text-6xl font-bold tracking-tight text-foreground text-balance"
          data-reveal="scale"
          data-speed="fast"
          data-easing="bounce"
          data-delay="100"
        >
          {hero.title}
        </h1>
        <p
          class="text-lg md:text-xl text-muted-foreground"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
          data-delay="200"
        >
          {hero.subtitle}
        </p>
      </div>

      <!-- CTA -->
      <div
        data-reveal="scale"
        data-speed="fast"
        data-easing="elastic"
        data-delay="350"
      >
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          id="hero-cta-primary"
        >
          <Button size="lg" withArrow>{hero.cta}</Button>
        </a>
      </div>
    </div>

    <!-- Columna derecha: globo terráqueo -->
    <div
      class="hidden md:flex items-center justify-center"
      data-reveal="scale"
      data-speed="normal"
      data-easing="soft"
      data-delay="400"
    >
      <Globe class="w-full max-w-[500px]"  />
    </div>
  </div>

  <script is:inline>
    document
      .getElementById("hero-cta-primary")
      ?.addEventListener("click", () => {
        if ("gtag" in window) {
          window.gtag("event", "cta_click", {
            event_category: "engagement",
            event_label: "hero-cta-primary",
          });
        }
      });
  </script>

  <!-- Logos: centrado, limitado a max-w-6xl -->
  <div
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
    data-delay="500"
    class="w-full max-w-6xl mx-auto"
  >
    <ClientsCarousel />
  </div>

  <!-- Animated sectors: centrado -->
  <div
    class="flex flex-col items-center gap-4 text-center w-full max-w-6xl mx-auto py-16"
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
    data-delay="700"
  >
    <p class="text-base text-muted-foreground uppercase tracking-widest">
      {hero.sectorsLabel}
    </p>
    <div class="sectors-container">
      {
        hero.sectors.map((sector, i) => (
          <span
            class="animated-sector text-4xl md:text-6xl font-bold text-primary"
            style={`--delay: ${i * 3}s; --total: ${totalDuration}s;`}
          >
            {sector}
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sectors-container {
    position: relative;
    height: 3.5rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .sectors-container {
      height: 5rem;
    }
  }

  .animated-sector {
    position: absolute;
    top: 0;
    left: 50%;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
    animation: sectorCycle var(--total) ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes sectorCycle {
    0% {
      opacity: 0;
      transform: translateX(-50%) translateY(20px);
    }
    5% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    28% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    33% {
      opacity: 0;
      transform: translateX(-50%) translateY(-20px);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) translateY(-20px);
    }
  }
</style>
