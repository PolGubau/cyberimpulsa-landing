---
import { branding } from "~/config/branding";
import { copy } from "~/shared/lib/copy";
import Button from "../ui/Button.astro";
import Globe from "../ui/Globe.astro";
import ClientsCarousel from "./ClientsCarousel.astro";

const { hero } = copy;
const { calendlyUrl } = branding.contact;
const totalDuration = hero.sectors.length * 3;
---

<section id="hero" class="relative flex flex-col w-full">
  <!-- Bloque superior: flex-col en mobile, grid 2 cols en desktop -->
  <div
    class="flex flex-col md:grid md:grid-cols-2 md:gap-8 md:items-center md:pt-20 pb-16 min-h-[80vh] md:max-w-6xl md:mx-auto md:w-full md:px-6"
  >
    <!-- Globo: arriba en mobile con degradado, columna derecha en desktop -->
    <div
      class="order-first md:order-last relative overflow-hidden md:overflow-visible
             h-[280px] md:h-auto
             md:flex md:items-center md:justify-center"
      data-reveal="scale"
      data-speed="normal"
      data-easing="soft"
      data-delay="400"
    >
      <Globe
        class="w-full md:max-w-[500px] translate-y-[2%] md:translate-y-0"
      />
      <!-- Degradado solo en mobile -->
      <div
        class="absolute bottom-0 left-0 right-0 h-36 bg-gradient-to-t from-background to-transparent pointer-events-none md:hidden"
      >
      </div>
    </div>

    <!-- Texto + CTA -->
    <div
      class="order-last md:order-first flex flex-col gap-10 justify-center md:items-start px-6 pt-4 pb-8 md:p-0"
    >
      <div
        class="flex flex-col items-center max-md:text-center md:items-start gap-4"
        data-stagger="120"
      >
        <h1
          class="text-4xl md:text-5xl font-bold tracking-tight text-foreground text-balance"
          data-reveal="scale"
          data-speed="fast"
          data-easing="bounce"
          data-delay="100"
        >
          {hero.title}
        </h1>
        <p
          class="text-lg md:text-xl text-muted-foreground text-balance"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
          data-delay="200"
        >
          {hero.subtitle}
        </p>
      </div>

      <!-- CTA -->
      <div
        data-reveal="scale"
        data-speed="fast"
        data-easing="elastic"
        data-delay="350"
        class="flex items-center gap-3 max-md:justify-center"
      >
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          id="hero-cta-primary"
        >
          <Button size="lg" withArrow>{hero.cta}</Button>
        </a>
        <a href="/clientes">
          <Button size="lg" variant="outline">Ver clientes</Button>
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    document
      .getElementById("hero-cta-primary")
      ?.addEventListener("click", () => {
        if ("gtag" in window) {
          window.gtag("event", "cta_click", {
            event_category: "engagement",
            event_label: "hero-cta-primary",
          });
        }
      });
  </script>

  <!-- Logos: centrado, limitado a max-w-6xl -->
  <div
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
    data-delay="500"
    class="w-full max-w-6xl mx-auto"
  >
    <ClientsCarousel />
  </div>

  <!-- Animated sectors: centrado -->
  <div
    class="flex flex-col items-center gap-4 text-center w-full max-w-6xl mx-auto py-16"
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
    data-delay="700"
  >
    <p class="text-base text-muted-foreground uppercase tracking-widest">
      {hero.sectorsLabel}
    </p>
    <div class="sectors-container">
      {
        hero.sectors.map((sector, i) => (
          <span
            class="animated-sector text-3xl sm:text-4xl md:text-6xl font-bold text-primary"
            style={`--delay: ${i * 3}s; --total: ${totalDuration}s;`}
          >
            {sector}
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sectors-container {
    position: relative;
    height: 6rem;
    width: 100%;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .sectors-container {
      height: 7rem;
    }
  }

  @media (min-width: 768px) {
    .sectors-container {
      height: 10rem;
    }
  }

  .animated-sector {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    white-space: normal;
    word-break: break-word;
    line-height: 1.15;
    opacity: 0;
    transform: translateY(20px);
    animation: sectorCycle var(--total) ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes sectorCycle {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    5% {
      opacity: 1;
      transform: translateY(0);
    }
    28% {
      opacity: 1;
      transform: translateY(0);
    }
    33% {
      opacity: 0;
      transform: translateY(-20px);
    }
    100% {
      opacity: 0;
      transform: translateY(-20px);
    }
  }
</style>
