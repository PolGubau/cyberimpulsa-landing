---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import ProjectsRail from "~/features/projects/ui/ProjectsRail.astro";
import { getProjects } from "~/shared/lib/collections";

const projects = await getProjects(2);
---

<section id="cases" class="landing-section">
  <SectionHeader
    tag="Casos de éxito"
    title="Empresas que ya captan más clientes B2B"
    description="Resultados reales de empresas de Cyberseguridad, Software e IA que implementaron nuestro sistema de captación."
    linkText="Ver todos"
    linkHref="/projects"
  />

  <ProjectsRail projects={projects} />
</section>
