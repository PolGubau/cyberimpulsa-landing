---
import { branding } from "~/config/branding";
import Button from "../ui/Button.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const values = [
  {
    icon: "🏆",
    title: "Especialistas, no generalistas",
    description:
      "Solo trabajamos con empresas B2B tecnológicas. Esa especialización nos hace mejores en lo que hacemos.",
  },
  {
    icon: "📈",
    title: "Obsesionados con los resultados",
    description:
      "Cada acción que tomamos se mide. Si no genera resultados, lo cambiamos. Sin excusas.",
  },
  {
    icon: "🤝",
    title: "Equipo de tu empresa",
    description:
      "No somos una agencia externa. Nos integramos en tu negocio y trabajamos como si fuéramos parte de tu equipo.",
  },
];
---

<section class="landing-section">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      tag="Nuestro equipo"
      title="Nos tomamos en serio"
      subtitle="crecer tu negocio."
      description="Somos una empresa de marketing especializada en hacer crecer empresas tecnológicas a través de estrategias B2B probadas."
      align="center"
    />

    <!-- Values -->
    <div class="grid md:grid-cols-3 gap-6 mb-20" data-stagger="100">
      {
        values.map((value) => (
          <div
            class="panel flex flex-col gap-3"
            data-reveal="bottom"
            data-speed="normal"
            data-easing="soft"
          >
            <div class="text-3xl">{value.icon}</div>
            <h3 class="text-lg font-bold text-foreground">{value.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              {value.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div
      class="text-center"
      data-reveal="scale"
      data-speed="fast"
      data-easing="elastic"
    >
      <a
        href={branding.contact.calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Button size="lg" withArrow
          >Conoce al equipo — Agenda una llamada</Button
        >
      </a>
    </div>
  </div>
</section>
