---
import { copy } from "~/shared/lib/copy";
import SectionHeader from "../ui/SectionHeader.astro";

const { method } = copy;
---

<section id="method" class="lg:py-32 px-6 max-w-7xl mx-auto">
  <div class="flex gap-24 w-full max-lg:flex-col">
    <div
      class="lg:sticky lg:top-32 self-start shrink-0 w-full lg:max-w-md flex flex-col justify-between gap-36"
    >
      <SectionHeader
        title="Nuestro método"
        descriptionClass="max-w-sm"
        subtitle="en 3 pasos"
        tag="Nuestro proceso"
        description="Un sistema de captación B2B probado y replicable. Adaptado a cada empresa tecnológica, con resultados desde el primer mes."
      />

      <div class="hidden lg:block">
        <div
          class="p-6 rounded-3xl shadow-pastel bg-accent border border-muted"
        >
          <p class="text-lg font-semibold text-foreground mb-3">
            ¿Por qué solo empresas B2B tech?
          </p>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Cyberseguridad, software e IA tienen ciclos de venta complejos y
            compradores técnicos. Necesitan una estrategia específica. Nosotros
            la tenemos probada.
          </p>
          <div
            class="mt-4 flex flex-col gap-2 text-sm text-primary font-medium"
          >
            <span>✓ Conocemos a tus compradores (CTOs, CISOs, CEOs)</span>
            <span>✓ Sabemos cómo comunicar valor técnico</span>
            <span>✓ Sistema adaptado a tu ciclo de ventas</span>
          </div>
        </div>
      </div>
    </div>

    <div class="relative space-y-24" data-stagger="150">
      <!-- Progress bar (background line) -->
      <div
        id="progress-bg"
        class="block absolute left-4 lg:left-5 w-0.5 bg-muted"
        style="top: 0; height: 0"
      >
      </div>
      <!-- Progress line (animated) -->
      <div
        id="progress-line"
        class="block absolute left-4 lg:left-5 w-0.5 bg-primary transition-all duration-300"
        style="top: 0; height: 0"
      >
      </div>
      {
        method.steps.map((step, index) => (
          <div
            class="method-step group relative"
            data-step={index}
            data-reveal="left"
            data-duration="600"
          >
            <div class="flex gap-8 items-start">
              <div class="relative z-10 shrink-0">
                <div
                  class="step-badge size-8 lg:size-10 flex items-center justify-center rounded-full bg-background border-2 border-muted font-semibold text-sm transition-all duration-500"
                  data-step-index={index}
                >
                  {index + 1}
                </div>
              </div>

              {/* Content */}
              <div class="flex-1 space-y-4 lg:pt-1">
                <div class="space-y-2">
                  <h3 class="text-xl lg:text-2xl font-semibold">
                    {step.title}
                  </h3>
                </div>
                <p class="text-muted-foreground leading-relaxed max-w-2xl">
                  {step.description}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function updateProgressBar() {
    const progressLine = document.getElementById("progress-line");
    const stepsContainer =
      document.querySelector(".method-step")?.parentElement;
    const stepBadges = document.querySelectorAll<HTMLElement>(".step-badge");

    if (!progressLine || !stepsContainer || stepBadges.length === 0) return;

    const scrollMidpoint = window.scrollY + window.innerHeight / 2;

    // All positions calculated from document top (stable across scroll)
    const containerTop =
      stepsContainer.getBoundingClientRect().top + window.scrollY;

    const firstBadge = stepBadges[0];
    const lastBadge = stepBadges[stepBadges.length - 1];

    const firstBadgeRect = firstBadge.getBoundingClientRect();
    const lastBadgeRect = lastBadge.getBoundingClientRect();

    const firstBadgeCenter =
      firstBadgeRect.top + window.scrollY + firstBadgeRect.height / 2;
    const lastBadgeCenter =
      lastBadgeRect.top + window.scrollY + lastBadgeRect.height / 2;

    // Line starts at first badge center, ends at last badge center
    const lineStart = firstBadgeCenter - containerTop;
    const lineEnd = lastBadgeCenter - containerTop;
    const totalLength = lineEnd - lineStart;

    const relativeScroll = scrollMidpoint - containerTop - lineStart;
    const currentLength = Math.max(0, Math.min(totalLength, relativeScroll));

    // Sync background track to same bounds as animated line
    const progressBg = document.getElementById("progress-bg");
    if (progressBg) {
      progressBg.style.top = `${lineStart}px`;
      progressBg.style.height = `${totalLength}px`;
    }

    progressLine.style.top = `${lineStart}px`;
    progressLine.style.height = `${currentLength}px`;

    // Activate badges
    const progressBottom = containerTop + lineStart + currentLength;
    stepBadges.forEach((badge) => {
      const badgeRect = badge.getBoundingClientRect();
      const badgeCenter = badgeRect.top + window.scrollY + badgeRect.height / 2;
      if (progressBottom >= badgeCenter) {
        badge.classList.add("active");
      } else {
        badge.classList.remove("active");
      }
    });
  }

  window.addEventListener("scroll", updateProgressBar, { passive: true });
  window.addEventListener("resize", updateProgressBar);
  setTimeout(updateProgressBar, 100);
</script>

<style>
  .step-badge {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .step-badge.active {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: var(--color-background);
    transform: scale(1.1);
  }
</style>
