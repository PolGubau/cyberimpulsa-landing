---
import { branding } from "~/config/branding";
import Button from "../ui/Button.astro";

const reasons = [
  {
    icon: "🛡️",
    title: "Todo cubierto",
    description:
      "Nuestro servicio cubre todo lo que necesitas para crecer. Desde la grabación del contenido hasta el cierre de ventas. Si buscas una solución parcial, no somos tu agencia.",
  },
  {
    icon: "🎯",
    title: "No improvisamos",
    description:
      "Conocemos tu sector y sabemos cómo generar resultados. Buscamos empresas que confíen en nosotros para impulsarlas, como ya lo hacemos con otros clientes. Sin pruebas ni errores a tu costa.",
  },
  {
    icon: "💰",
    title: "100% Rentable",
    description:
      "Al trabajar con empresas del sector tech con precios elevados, el retorno que consigues es muy superior a la inversión inicial. Si no buscas rentabilidad, este no es tu lugar.",
  },
];
---

<section class="landing-section">
  <div class="max-w-4xl mx-auto" data-stagger="100">
    <div
      class="text-center mb-12"
      data-reveal="scale"
      data-speed="normal"
      data-easing="bounce"
    >
      <span
        class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-semibold mb-4"
      >
        Sé honesto contigo mismo
      </span>
      <h2
        class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
      >
        3 Motivos para <span class="text-primary">NO elegirnos</span>
      </h2>
      <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
        Somos directos. Si alguno de estos puntos te describe, probablemente no
        somos la opción correcta para ti.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6" data-stagger="120">
      {
        reasons.map((reason) => (
          <div
            class="panel flex flex-col gap-4"
            data-reveal="bottom"
            data-speed="normal"
            data-easing="soft"
          >
            <div class="text-4xl">{reason.icon}</div>
            <h3 class="text-xl font-bold text-foreground">{reason.title}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {reason.description}
            </p>
          </div>
        ))
      }
    </div>

    <div
      class="text-center mt-12"
      data-reveal="scale"
      data-speed="fast"
      data-easing="elastic"
    >
      <p class="text-muted-foreground mb-6">
        ¿Sigues aquí? Entonces probablemente sí encajamos. Hablemos.
      </p>
      <a
        href={branding.contact.calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Button size="lg" withArrow> Agenda una consulta gratuita </Button>
      </a>
    </div>
  </div>
</section>
