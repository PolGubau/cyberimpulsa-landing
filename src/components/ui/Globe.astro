---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["globe-wrapper", className]}>
  <canvas id="cobe-globe"></canvas>
</div>

<script>
  import createGlobe from "cobe";

  // Wait for layout to be painted so offsetWidth is correct
  window.addEventListener("load", () => {
    const canvas = document.getElementById("cobe-globe") as HTMLCanvasElement;
    if (!canvas) return;

    const SIZE = 600;
    canvas.width = SIZE * 2;
    canvas.height = SIZE * 2;

    let phi = 0;
    let rafId: number;

    const globe = createGlobe(canvas, {
      devicePixelRatio: 2,
      width: SIZE * 2,
      height: SIZE * 2,
      phi: 0,
      theta: 0.2,
      dark: 0,
      diffuse: 1.4,
      mapSamples: 16000,
      mapBrightness: 6,
      baseColor: [0.95, 0.95, 0.98],
      markerColor: [0.153, 0.161, 0.259],
      glowColor: [0.9, 0.9, 1],
      markers: [
        { location: [41.3851, 2.1734], size: 0.05 }, // Barcelona
        { location: [40.4168, -3.7038], size: 0.04 }, // Madrid
        { location: [25.7617, -80.1918], size: 0.04 }, // Miami
        { location: [51.5074, -0.1278], size: 0.04 }, // London
        { location: [19.4326, -99.1332], size: 0.04 }, // México DF
      ],
    });

    function animate() {
      phi += 0.004;
      globe.update({ phi });
      rafId = requestAnimationFrame(animate);
    }
    animate();

    // Cleanup on Astro page transitions
    document.addEventListener(
      "astro:before-swap",
      () => {
        cancelAnimationFrame(rafId);
        globe.destroy();
      },
      { once: true },
    );
  });
</script>

<style>
  .globe-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1;
  }

  canvas {
    width: 100% !important;
    height: 100% !important;
  }
</style>
