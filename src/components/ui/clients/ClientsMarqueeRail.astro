---
import { Image } from "astro:assets";
import autoboost from "~/assets/media/logos/autoboost.webp";
import cloudGroup from "~/assets/media/logos/cloud-group.webp";
import cometa from "~/assets/media/logos/cometa.webp";
import nexian from "~/assets/media/logos/nexian.webp";
import olliria from "~/assets/media/logos/olliria.webp";
import rv from "~/assets/media/logos/rv.webp";

const logos = [
  { src: cometa, alt: "Cometa Labs" },
  { src: cloudGroup, alt: "The Cloud Group" },
  { src: nexian, alt: "Nexian Labs" },
  { src: autoboost, alt: "Autoboost" },
  { src: olliria, alt: "Olliria" },
  { src: rv, alt: "RV" },
];
---

<div class="marquee-wrapper">
  <div class="marquee-container">
    <div class="marquee-fade bg-linear-to-r from-background left-0"></div>
    <div class="marquee-fade bg-linear-to-l from-background right-0"></div>

    <div class="marquee-content">
      {
        [...logos, ...logos, ...logos, ...logos].map((logo) => (
          <div class="logo-item">
            <Image
              src={logo.src}
              alt={logo.alt}
              height={48}
              width={180}
              class="h-12 w-auto max-w-[180px] object-contain"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  /* Wrapper que toma el ancho del contenedor padre */
  .marquee-wrapper {
    width: 100%;
    position: relative;
  }

  /* Contenedor con overflow hidden */
  .marquee-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Degradados que se adaptan al contenedor */
  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(80px, 15vw, 200px); /* Responsive width */
    z-index: 10;
    pointer-events: none;
  }

  /* Contenido que se desplaza */
  .marquee-content {
    display: flex;
    gap: 4rem;
    padding-bottom: 2.5rem;
    animation: scroll 20s linear infinite;
    will-change: transform;
  }

  /* Animación de scroll - Ajustada para 4 copias (100% / 4 = 25%) */
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-25%);
    }
  }

  /* Velocidad en móvil */
  @media (max-width: 768px) {
    .marquee-content {
      animation-duration: 20s;
      gap: 2rem;
    }
  }

  /* Pausa al hover */
  .marquee-content:hover {
    animation-play-state: paused;
  }

  .logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 300ms ease;
  }

  .logo-item:hover {
    opacity: 1;
  }
</style>
