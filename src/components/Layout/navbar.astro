---
import { Image } from "astro:assets";
import isoLogo from "~/assets/media/branding/iso.svg";
import Button from "~/components/ui/Button.astro";
import { branding } from "~/config/branding";
import { copy } from "~/shared/lib/copy";

const desktopNavItems = [
  { href: "/nosotros", label: copy.nav.about },
  { href: "/clientes", label: copy.nav.clients },
  { href: "/sistema", label: copy.nav.system },
];

const mobileNavItems = [
  { href: "/", label: copy.nav.home },
  ...desktopNavItems,
];

const pathname = Astro.url.pathname;
---

<header
  data-reveal="top"
  class="fixed w-[calc(100vw-2rem)] max-w-[90vw] lg:w-fit rounded-full top-6 left-1/2 -translate-x-1/2 z-50 bg-accent/90 backdrop-blur-md shadow-pastel-sm flex items-center justify-between p-2 gap-2 lg:gap-6"
>
  <!-- Logo -->
  <a
    href="/"
    class="flex cursor-pointer items-center gap-2 hover:opacity-80 transition-opacity px-2"
  >
    <Image
      src={isoLogo}
      alt={branding.name}
      width={28}
      height={28}
      class="size-5 object-contain"
    />
    <!-- Nombre siempre visible -->
    <span class="text-xl font-bold text-primary">{branding.name}</span>
  </a>

  <!-- Desktop Navigation -->
  <nav class="hidden lg:flex items-center">
    {
      desktopNavItems.map((item) => {
        const isActive =
          pathname === item.href ||
          (item.href !== "/" && pathname.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`py-2 px-4 text-sm font-medium transition-colors ${isActive ? "text-foreground underline" : "text-muted-foreground hover:underline"}`}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <!-- Mobile Menu Button -->
  <button
    id="mobile-menu-button"
    class="lg:hidden p-2 text-foreground hover:bg-accent rounded-full transition-colors"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <svg
      id="hamburger-icon"
      class="size-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line id="bar-top" x1="4" y1="6" x2="20" y2="6"></line>
      <line id="bar-mid" x1="4" y1="12" x2="20" y2="12"></line>
      <line id="bar-bot" x1="4" y1="18" x2="20" y2="18"></line>
    </svg>
  </button>

  <!-- Actions -->
  <div class="hidden lg:flex items-center gap-4">
    <a
      href={branding.contact.calendlyUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Button size="sm" withArrow>Agenda llamada</Button>
    </a>
  </div>
</header>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 lg:hidden bg-background/95 backdrop-blur-md pointer-events-none opacity-0 transition-opacity duration-300"
  aria-hidden="true"
>
  <nav class="flex flex-col items-center justify-center h-full gap-8">
    {
      mobileNavItems.map((item, i) => {
        const isActive =
          pathname === item.href ||
          (item.href !== "/" && pathname.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`mobile-menu-link text-2xl font-medium transition-colors translate-y-4 opacity-0 ${isActive ? "text-primary underline" : "text-foreground hover:text-primary"}`}
            style={`transition: opacity 300ms ${80 + i * 60}ms, transform 300ms ${80 + i * 60}ms;`}
          >
            {item.label}
          </a>
        );
      })
    }
    <a
      href={branding.contact.calendlyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-menu-link translate-y-4 opacity-0"
      style={`transition: opacity 300ms ${80 + mobileNavItems.length * 60}ms, transform 300ms ${80 + mobileNavItems.length * 60}ms;`}
    >
      <Button size="lg" withArrow>Agenda llamada</Button>
    </a>
  </nav>
</div>

<script>
  function initNavbar() {
    // Mobile menu
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const barTop = document.getElementById("bar-top") as SVGLineElement | null;
    const barMid = document.getElementById("bar-mid") as SVGLineElement | null;
    const barBot = document.getElementById("bar-bot") as SVGLineElement | null;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      mobileMenu?.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu?.classList.add("opacity-100");
      menuButton?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      // bars → X: translateY to center, then rotate around own center
      if (barTop) {
        barTop.style.transform = "translateY(6px) rotate(45deg)";
      }
      if (barMid) {
        barMid.style.opacity = "0";
        barMid.style.transform = "scaleX(0)";
      }
      if (barBot) {
        barBot.style.transform = "translateY(-6px) rotate(-45deg)";
      }

      mobileMenu
        ?.querySelectorAll<HTMLElement>(".mobile-menu-link")
        .forEach((el) => {
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
        });
    }

    function closeMenu() {
      isOpen = false;
      mobileMenu?.classList.add("opacity-0", "pointer-events-none");
      mobileMenu?.classList.remove("opacity-100");
      menuButton?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";

      // X → bars
      if (barTop) {
        barTop.style.transform = "";
      }
      if (barMid) {
        barMid.style.opacity = "1";
        barMid.style.transform = "";
      }
      if (barBot) {
        barBot.style.transform = "";
      }

      mobileMenu
        ?.querySelectorAll<HTMLElement>(".mobile-menu-link")
        .forEach((el) => {
          el.style.opacity = "0";
          el.style.transform = "translateY(1rem)";
        });
    }

    menuButton?.addEventListener("click", () =>
      isOpen ? closeMenu() : openMenu(),
    );
    document.querySelectorAll(".mobile-menu-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Re-init on every page load (View Transitions compatible)
  document.addEventListener("astro:page-load", initNavbar);
</script>

<!-- Spacer to prevent content from going under fixed header -->
<div class="h-20"></div>

<style>
  #bar-top,
  #bar-mid,
  #bar-bot {
    transform-box: fill-box;
    transform-origin: center;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }
</style>
