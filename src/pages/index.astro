---
import MainLayout from "~/layouts/MainLayout.astro";

import ClientsShowcase from "~/components/sections/ClientsShowcase.astro";
import Hero from "~/components/sections/Hero.astro";
import Hype from "~/components/sections/Hype.astro";
import Impact from "~/components/sections/Impact.astro";
import Method from "~/components/sections/Method.astro";

const title = "Cyberimpulsa | Captación B2B para Cyberseguridad, Software e IA";
const description =
    "Ayudamos a crecer empresas de Cyberseguridad, Desarrollo de software/app e Inteligencia Artificial. Sistema de captación B2B con resultados en los primeros 2 meses.";
---

<MainLayout title={title} description={description}>
    <Hero />
    <Impact />
    <ClientsShowcase />
    <Method />
    <Hype />
</MainLayout>
