---
import { render } from "astro:content";
import Button from "~/components/ui/Button.astro";
import { branding } from "~/config/branding";
import MainLayout from "~/layouts/MainLayout.astro";
import { getClients } from "~/shared/lib/collections";

const cases = await getClients();

// Pre-render MDX bodies
const renderedCases = await Promise.all(
  cases.map(async (c) => {
    const { Content } = await render(c);
    return { ...c, Content };
  }),
);
---

<MainLayout
  title="Clientes | Cyberimpulsa - Casos de Éxito B2B"
  description="Casos reales donde estrategia y marketing se unen para cumplir objetivos de empresas B2B tecnológicas."
>
  <!-- Hero -->
  <section
    class="landing-section pt-32 text-center flex flex-col items-center gap-6"
  >
    <div data-reveal="scale" data-speed="fast" data-easing="bounce">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-foreground">
        Cómo ayudamos a crecer a
      </h1>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-primary">
        otras empresas.
      </h1>
    </div>
    <p
      class="text-lg text-muted-foreground max-w-2xl"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
    >
      Casos reales donde estrategia y marketing se unen para cumplir objetivos
      de empresas B2B tecnológicas.
    </p>
  </section>

  <!-- Cases -->
  <section class="landing-section">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8" data-stagger="100">
      {
        renderedCases.map(({ data, Content }) => (
          <div
            class="panel flex flex-col gap-5"
            data-reveal="bottom"
            data-speed="normal"
            data-easing="soft"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-bold text-foreground text-xl">{data.client}</p>
                <p class="text-primary text-sm font-medium">{data.type}</p>
              </div>
              <span class="shrink-0 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold">
                {data.tag}
              </span>
            </div>
            <div class="text-muted-foreground leading-relaxed prose prose-sm max-w-none">
              <Content />
            </div>
            <div class="pt-2 border-t border-muted">
              <p class="text-3xl font-bold text-primary">{data.metric}</p>
              <p class="text-sm text-muted-foreground">{data.metricLabel}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="landing-section text-center flex flex-col items-center gap-6">
    <h2
      class="text-3xl font-bold text-foreground"
      data-reveal="scale"
      data-speed="normal"
      data-easing="bounce"
    >
      ¿Tu empresa es la próxima?
    </h2>
    <p
      class="text-muted-foreground max-w-md"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
    >
      Agenda una consulta gratuita y analizamos tu situación sin compromiso.
    </p>
    <div data-reveal="scale" data-speed="fast" data-easing="elastic">
      <a
        href={branding.contact.calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Button size="lg" withArrow>Agenda llamada gratuita</Button>
      </a>
    </div>
  </section>
</MainLayout>
